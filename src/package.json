{
  "name": "@react-native-community/checkbox",
  "version": "0.5.20",
  "description": "React Native Checkbox native modules for Android , iOS and Windows",
  "keywords": [
    "checkbox",
    "react native",
    "react-native"
  ],
  "homepage": "https://github.com/react-native-community/react-native-checkbox#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/react-native-community/react-native-checkbox.git"
  },
  "license": "MIT",
  "author": "Nicholas Lee <nicholaslee119@gmail.com>",
  "main": "dist/CheckBox",
  "types": "typings/index.d.ts",
  "scripts": {
    "build": "tsc",
    "windows": "npx @react-native-community/cli run-windows",
    "test:windows": "jest --config jest.config.windows.js"
  },
  "devDependencies": {
    "@babel/core": "^7.8.3",
    "@babel/plugin-proposal-class-properties": "^7.4.0",
    "@react-native-community/eslint-config": "^1.1.0",
    "@react-native-community/eslint-plugin": "^1.0.0",
    "@types/jest": "^24.0.25",
    "@types/react": "^19.1.0",
    "@types/react-test-renderer": "16.9.0",
    "babel-plugin-module-resolver": "^3.1.3",
    "detox": "^16.4.1",
    "eslint": "^6.8.0",
    "eslint-plugin-prettier": "^3.1.2",
    "jest": "^24.7.1",
    "metro-react-native-babel-preset": "0.59.0",
    "prettier": "^2.0.5",
    "react": "19.1.0",
    "react-native": "0.80.0",
    "react-native-windows": "file:C:/Users/anuverma/Desktop/GitHub/react-native-windows/vnext",
    "react-test-renderer": "16.9.0",
    "ts-jest": "^24.2.0",
    "typescript": "^5.7.0",
    "xcpretty": "^0.2.8001",
    "metro-config": "^0.82.5",
    "@rnx-kit/jest-preset": "^0.1.17"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": ">= 0.62",
    "react-native-windows": ">=0.62"
  },
  "peerDependenciesMeta": {
    "react-native-windows": {
      "optional": true
    }
  },
  "codegenConfig": {
    "name": "WindowsCheckBoxComponent",
    "type": "all",
    "jsSrcsDir": "js",
    "includesGeneratedCode": true,
    "windows": {
      "namespace": "CheckboxCodegen",
      "outputDirectory": "windows/Checkbox/codegen",
      "separateDataTypes": true,
      "generators": [
        "modulesWindows",
        "componentsWindows"
      ]
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "eslintConfig": {
    "extends": "@react-native-community",
    "env": {
      "es6": true,
      "jest": true
    },
    "globals": {
      "it": true,
      "expect": true,
      "element": true,
      "describe": true,
      "by": true,
      "device": true,
      "beforeAll": true,
      "beforeEach": true,
      "afterAll": true,
      "jest": true,
      "jasmine": true
    }
  },
  "react-native-windows": {
    "init-windows": {
      "name": "Checkbox",
      "namespace": "Checkbox",
      "template": "cpp-lib"
    }
  }
}
