{
  "name": "@react-native-community/checkbox",
  "version": "0.5.20",
  "description": "React Native Checkbox native modules for Android, iOS, and Windows",
  "keywords": ["checkbox", "react native", "react-native"],
  "homepage": "https://github.com/react-native-community/react-native-checkbox#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/react-native-community/react-native-checkbox.git"
  },
  "license": "MIT",
  "author": "Nicholas Lee <nicholaslee119@gmail.com>",
  "main": "dist/CheckBox",
  "types": "typings/index.d.ts",

  "scripts": {
    "build": "tsc",
    "windows": "npx @react-native-community/cli run-windows",
    "test:windows": "jest --config jest.config.windows.js"
  },

  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@react-native-community/eslint-config": "3.2.0",
    "@types/jest": "^29.5.12",
    "@types/react": "^18.3.7",
    "@types/react-test-renderer": "^18.3.1",
    "babel-plugin-module-resolver": "^5.0.0",
    "detox": "^20.17.0",
    "eslint": "^9.10.0",
    "eslint-plugin-prettier": "^5.2.1",
    "jest": "^29.7.0",
    "metro-config": "^0.81.0",
    "metro-react-native-babel-preset": "0.77.0",
    "prettier": "^3.2.5",
    "react": "19.0.0",
    "react-native": "0.82.0-nightly-20250806-5936f29d6",
    "react-native-windows": "0.0.0-canary.1020",
    "react-test-renderer": "19.0.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.0",
    "xcpretty": "0.2.8001",
    "@rnx-kit/jest-preset": "0.3.0"
  },

  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.63",
    "react-native-windows": ">=0.63"
  },

  "peerDependenciesMeta": {
    "react-native-windows": {
      "optional": true
    }
  },

  "codegenConfig": {
    "name": "RNCCheckboxSpec",
    "type": "all",
    "jsSrcsDir": "specs",
    "windows": {
      "namespace": "CheckboxCodegen",
      "outputDirectory": "windows/Checkbox/codegen",
      "separateDataTypes": true,
      "modulesWindows": true,
      "componentsWindows": true
    }
  },

  "publishConfig": {
    "access": "public"
  },

  "eslintConfig": {
    "extends": "@react-native-community",
    "env": {
      "es6": true,
      "jest": true
    },
    "globals": {
      "it": true,
      "expect": true,
      "element": true,
      "describe": true,
      "by": true,
      "device": true,
      "beforeAll": true,
      "beforeEach": true,
      "afterAll": true,
      "jest": true,
      "jasmine": true
    }
  },

  "react-native-windows": {
    "init-windows": {
      "name": "Checkbox",
      "namespace": "Checkbox",
      "template": "cpp-lib"
    }
  }
}
